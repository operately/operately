<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= @title %> - Operately</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(254, 245, 237, 1);
        color: #12233d;
        font-family: "Inter", sans-serif;
        font-size: 16px;
      }
      .card {
        width: min(620px, 92vw);
        background: #fff;
        border: 1px solid #dbe5f3;
        border-radius: 18px;
        box-shadow: 0 24px 80px rgba(2, 79, 172, 0.10);
        padding: 32px;
      }
      .logo {
        width: 40px;
        height: 40px;
        display: block;
      }
      .brand-name {
        margin: 16px 0 0;
        font-size: 24px;
        font-weight: 700;
        line-height: 1.2;
      }
      .description {
        margin: 32px 0 24px;
        color: rgba(0, 0, 0, 0.6);
        line-height: 1.5;
      }
      dl {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 10px 16px;
        margin: 0 0 24px;
      }
      dt { color: rgba(0, 0, 0, 0.6); font-weight: 600; }
      dd { margin: 0; }
      .warning {
        margin-bottom: 24px;
        border: 1px solid #f2d17d;
        background: #fff8df;
        color: #7a5600;
        border-radius: 12px;
        padding: 12px 14px;
        line-height: 1.5;
      }
      .actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
      }
      button {
        appearance: none;
        position: relative;
        display: inline-block;
        flex-grow: 0;
        flex-shrink: 0;
        border-radius: 6px;
        font-weight: 600;
        padding: 10px 20px;
        cursor: pointer;
        text-align: center;
        transition: all 100ms;
      }
      .approve {
        border: 1px solid #3185ff;
        background: #3185ff;
        color: rgba(255, 255, 255, 1);
      }
      .approve:hover {
        background: #2563eb;
        border-color: #2563eb;
      }
      .deny {
        border: 1px solid rgba(211, 204, 189, 1);
        background: rgba(255, 255, 255, 1);
        color: rgba(0, 0, 0, 0.6);
      }
      .deny:hover {
        color: rgba(0, 0, 0, 1);
        background: rgba(251, 251, 251, 1);
      }
    </style>
  </head>
  <body>
    <div class="card">
      <._logo />
      <p class="description"><strong><%= @request.client.client_name %></strong> is requesting access to your Operately workspace through MCP.</p>

      <%= if @localhost_warning do %>
        <div class="warning">
          This client uses a localhost redirect URI. Confirm that you trust the local application before approving.
        </div>
      <% end %>

      <%= if "mcp:write" in @request.scopes do %>
        <div class="warning">
          Write access lets this client create, update, delete, and archive content in your workspace.
        </div>
      <% end %>

      <dl>
        <dt>Client</dt>
        <dd><%= @request.client.client_name %></dd>

        <dt>Client Host</dt>
        <dd><%= @client_host %></dd>

        <dt>Redirect Host</dt>
        <dd><%= @redirect_host %></dd>

        <dt>Company</dt>
        <dd><%= @company.name %></dd>

        <dt>Permissions</dt>
        <dd>
          <ul style="margin: 0; padding-left: 20px;">
            <%= for scope <- @request.scopes do %>
              <li><%= Operately.Mcp.scope_label(scope) %></li>
            <% end %>
          </ul>
        </dd>
      </dl>

      <form method="post" action="/oauth/authorize">
        <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
        <%= for {key, value} <- @hidden_fields do %>
          <%= if value do %>
            <input type="hidden" name={key} value={value} />
          <% end %>
        <% end %>

        <div class="actions">
          <button class="deny" type="submit" name="decision" value="deny">Deny</button>
          <button class="approve" type="submit" name="decision" value="approve">Authorize</button>
        </div>
      </form>
    </div>
  </body>
</html>
