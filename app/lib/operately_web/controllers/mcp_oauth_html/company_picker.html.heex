<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= @title %> - Operately</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(254, 245, 237, 1);
        color: #12233d;
        font-family: "Inter", sans-serif;
        font-size: 16px;
      }
      .card {
        width: min(560px, 92vw);
        background: #fff;
        border: 1px solid #dbe5f3;
        border-radius: 18px;
        box-shadow: 0 24px 80px rgba(2, 79, 172, 0.10);
        padding: 32px;
      }
      .logo {
        width: 40px;
        height: 40px;
        display: block;
      }
      .brand-name {
        margin: 16px 0 0;
        font-size: 24px;
        font-weight: 700;
        line-height: 1.2;
      }
      .description {
        margin: 32px 0;
        color: rgba(0, 0, 0, 0.6);
        line-height: 1.5;
      }
      .company {
        display: block;
        border: 1px solid #dbe5f3;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 12px;
      }
      .actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 24px;
      }
      button.primary {
        appearance: none;
        position: relative;
        display: inline-block;
        flex-grow: 0;
        flex-shrink: 0;
        border: 1px solid #3185ff;
        border-radius: 6px;
        background: #3185ff;
        color: rgba(255, 255, 255, 1);
        font-weight: 600;
        padding: 10px 20px;
        cursor: pointer;
        text-align: center;
        transition: all 100ms;
      }
      button.primary:hover {
        background: #2563eb;
        border-color: #2563eb;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <._logo />
      <p class="description"><strong><%= @request.client.client_name %></strong> wants to connect to Operately. Choose which company to use for this connection.</p>

      <form method="post" action="/oauth/authorize">
        <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
        <input type="hidden" name="decision" value="select_company" />
        <%= for {key, value} <- @hidden_fields do %>
          <%= if value do %>
            <input type="hidden" name={key} value={value} />
          <% end %>
        <% end %>

        <%= for {company, index} <- Enum.with_index(@companies) do %>
          <label class="company">
            <input type="radio" name="selected_company_id" value={company.id} checked={index == 0} />
            <span><%= company.name %></span>
          </label>
        <% end %>

        <div class="actions">
          <button class="primary" type="submit">Continue</button>
        </div>
      </form>
    </div>
  </body>
</html>
