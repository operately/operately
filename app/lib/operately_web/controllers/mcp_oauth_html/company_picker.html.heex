<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= @title %> - Operately</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(160deg, #f6f8fb 0%, #eef3fb 100%);
        color: #12233d;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }
      .card {
        width: min(560px, 92vw);
        background: #fff;
        border: 1px solid #dbe5f3;
        border-radius: 18px;
        box-shadow: 0 24px 80px rgba(2, 79, 172, 0.10);
        padding: 32px;
      }
      h1 { margin: 0 0 10px; font-size: 24px; }
      p { margin: 0 0 24px; color: #4b5d78; line-height: 1.5; }
      .company {
        display: block;
        border: 1px solid #dbe5f3;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 12px;
      }
      .actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 24px;
      }
      button {
        appearance: none;
        border: 0;
        border-radius: 10px;
        background: #024fac;
        color: white;
        font-size: 14px;
        font-weight: 600;
        padding: 12px 18px;
        cursor: pointer;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1><%= @title %></h1>
      <p><strong><%= @request.client.client_name %></strong> wants to connect to Operately. Choose which company this MCP connection should use.</p>

      <form method="post" action="/oauth/authorize">
        <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
        <input type="hidden" name="decision" value="select_company" />
        <%= for {key, value} <- @hidden_fields do %>
          <%= if value do %>
            <input type="hidden" name={key} value={value} />
          <% end %>
        <% end %>

        <%= for {company, index} <- Enum.with_index(@companies) do %>
          <label class="company">
            <input type="radio" name="selected_company_id" value={company.id} checked={index == 0} />
            <span><%= company.name %></span>
          </label>
        <% end %>

        <div class="actions">
          <button type="submit">Continue</button>
        </div>
      </form>
    </div>
  </body>
</html>
