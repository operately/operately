<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= @title %> - Operately</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f6f8fb;
        color: #12233d;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }
      .card {
        width: min(520px, 92vw);
        background: #fff;
        border: 1px solid #dbe5f3;
        border-radius: 18px;
        box-shadow: 0 24px 80px rgba(2, 79, 172, 0.08);
        padding: 32px;
      }
      h1 { margin: 0 0 12px; font-size: 24px; }
      p { margin: 0; color: #4b5d78; line-height: 1.5; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1><%= @title %></h1>
      <p><%= @message %></p>
    </div>
  </body>
</html>
