<%= title("Updates from the last #{@window_minutes} minutes") %>

<%= spacer() %>

<%= if Enum.empty?(@parent_groups) do %>
  <%= digest_empty_state("You're all caught up", "No new updates came in during the last #{@window_minutes} minutes.") %>
<% else %>
  <%= for group <- @parent_groups do %>
    <%= digest_group(group) %>
  <% end %>
<% end %>
