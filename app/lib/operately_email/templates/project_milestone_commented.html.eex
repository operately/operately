<%= title("#{short_name(@author)} #{@action_text}") %>

<%= spacer() %>

<%= if @content not in [nil, %{}] do %>
  <%= row do %>
      <%= rich_text(@content) %>
  <% end %>
<% end %>

<%= if @next_milestone do %>
  <%= spacer() %>

  <%= row do %>
    <div style="font-weight: 700; margin-bottom: 8px;">Next milestone</div>
    <div><%= @next_milestone.title %></div>
  <% end %>
<% end %>

<%= spacer() %>

<%= row do %>
  <%= cta_button(@link, @button_text) %>
<% end %>
