{
  "name": "operately-cli",
  "version": "0.1.0",
  "description": "Official CLI for Operately external API",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "./dist/index.js",
  "bin": {
    "operately": "./dist/index.js",
    "op": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "docs/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test dist/test",
    "gen:catalog": "echo \"Catalog is generated by 'make gen.api.catalog'\"",
    "gen:commands": "node scripts/gen-commands-doc.mjs",
    "check:catalog": "node scripts/check-catalog-sync.mjs"
  },
  "dependencies": {
    "axios": "^1.7.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.4.3"
  }
}
