{
  "name": "@operately/operately-cli",
  "version": "1.5.0",
  "description": "Official CLI for Operately external API",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "./dist/index.js",
  "bin": {
    "operately": "dist/index.js",
    "op": "dist/index.js"
  },
  "files": [
    "dist/**",
    "docs/**"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test 'dist/test/**/*.test.js'",
    "gen:catalog": "echo \"Catalog is generated by 'make gen.api.catalog'\"",
    "gen:commands": "node scripts/gen-commands-doc.mjs",
    "check:catalog": "node scripts/check-catalog-sync.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tiptap/core": "^2.1.13",
    "@tiptap/extension-highlight": "^2.1.13",
    "@tiptap/extension-link": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "jsdom": "^23.0.1",
    "marked": "^11.1.1",
    "axios": "^1.7.3"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@types/node": "^22.10.2",
    "typescript": "^5.4.3"
  }
}
