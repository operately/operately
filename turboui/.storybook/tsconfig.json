{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".."
  },
  "include": [
    "./main.ts",
    "./preview.tsx",
    "./preview.d.ts",
    "./router.tsx",
    "./vite.config.ts",
    "../src/global.d.ts"
  ]
}
