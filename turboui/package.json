  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "clean": "rm -rf node_modules && rm -rf dist",
    "storybook": "storybook dev -p $PORT_STORYBOOK_SERVER",
    "build-storybook": "storybook build",
    "test": "jest",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "npm run build-storybook -- --quiet && concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --ci --junit\""
  },
